# Copia este archivo a .env y completa tus credenciales reales.
UA_USUARIO=tu_correo@cloud.uautonoma.cl
UA_CONTRASENA=tu_contrasena
UA_TOTP_SECRET=TU_SECRETO_TOTP
UA_MANTENER_SESION=true

# Opcional: periodo/nivel objetivo para extracciones puntuales.
UA_TARGET_TERM_CODE=202510
UA_TARGET_TERM_DESCRIPTION=Primer Semestre - 2025
UA_TARGET_LEVEL_CODE=PR
UA_TARGET_LEVEL_DESCRIPTION=Pregrado

# Opcional: comportamiento del browser.
UA_HEADLESS=false
UA_SLOW_MO=400
UA_PAGE_SIZE=200

# Opcional: salida local y dashboard.
UA_OUTPUT_DIR=data
UA_SQLITE_PATH=data/ua_grades.sqlite3
UA_WEB_HOST=127.0.0.1
UA_WEB_PORT=8000
