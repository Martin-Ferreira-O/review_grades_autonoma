# Copia este archivo a .env y completa tus credenciales reales.
UAC_USUARIO=tu_correo@cloud.uautonoma.cl
UAC_CONTRASENA=tu_contrasena
UAC_TOTP_SECRET=TU_SECRETO_TOTP
UAC_MANTENER_SESION=true

# Opcional: período/nivel objetivo para la extracción.
UAC_TARGET_TERM_CODE=202510
UAC_TARGET_TERM_DESCRIPTION=Primer Semestre - 2025
UAC_TARGET_LEVEL_CODE=PR
UAC_TARGET_LEVEL_DESCRIPTION=Pregrado

# Opcional: comportamiento del browser.
UAC_HEADLESS=false
UAC_SLOW_MO=400
UAC_PAGE_SIZE=200
